<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ClienteMovil.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vista="clr-namespace:ClienteMovil.Vista"
    Title="ClienteMovil"
    FlyoutBehavior="Disabled">

    <ShellContent
        Route="login"
        ContentTemplate="{DataTemplate vista:LoginPage}" />

    <ShellContent
        Route="conversion"
        ContentTemplate="{DataTemplate vista:ConversionPage}" />

</Shell>