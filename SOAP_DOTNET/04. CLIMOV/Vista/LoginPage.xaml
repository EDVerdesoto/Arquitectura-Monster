<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ClienteMovil.Vista.LoginPage"
             BackgroundColor="#0D0D0D">

    <ScrollView>
        <Grid Padding="10" 
              RowDefinitions="Auto"
              ColumnDefinitions="Auto, Auto" 
              HorizontalOptions="Center"
              VerticalOptions="Center"
              ColumnSpacing="20">

            <VerticalStackLayout Grid.Column="0" Spacing="20" WidthRequest="170" VerticalOptions="Center">

                <Label Text="Ingrese sus&#x0a;credenciales:"
                       FontSize="22"
                       FontAttributes="Bold,Italic"
                       TextColor="#F2F2F2"
                       HorizontalOptions="Start"
                       Margin="0,0,0,10" />

                <Border x:Name="MensajeFrame"
                        IsVisible="false"
                        Padding="6"
                        StrokeShape="RoundRectangle 8"
                        StrokeThickness="0"
                        Margin="0,0,0,10">
                    <Label x:Name="MensajeLabel"
                           FontSize="14"
                           TextColor="#F2F2F2"
                           HorizontalOptions="Center" />
                </Border>

                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="5" RowDefinitions="Auto, Auto" RowSpacing="12">
                    <Label Grid.Row="0" Grid.Column="0" Text="Usuario:" FontSize="16" TextColor="#F2F2F2" VerticalOptions="Center" FontAttributes="Bold" />
                    <!-- Envolvemos los Entry con Border para simular el fondo -->
                    <Border Grid.Row="0" Grid.Column="1" BackgroundColor="White" StrokeThickness="0" HeightRequest="35">
                        <Entry x:Name="UsuarioEntry" TextColor="Black" BackgroundColor="Transparent" FontSize="14" VerticalOptions="Center" />
                    </Border>

                    <Label Grid.Row="1" Grid.Column="0" Text="Clave:" FontSize="16" TextColor="#F2F2F2" VerticalOptions="Center" FontAttributes="Bold" />
                    <Border Grid.Row="1" Grid.Column="1" BackgroundColor="White" StrokeThickness="0" HeightRequest="35">
                        <Entry x:Name="ClaveEntry" TextColor="Black" BackgroundColor="Transparent" FontSize="14" IsPassword="True" VerticalOptions="Center" />
                    </Border>
                </Grid>

                <Button x:Name="LoginButton"
                        Text="INICIAR&#x0a;SESIÓN"
                        FontAttributes="Bold"
                        FontSize="14"
                        BackgroundColor="#5c7df2"
                        TextColor="White"
                        CornerRadius="4"
                        HeightRequest="60"
                        WidthRequest="150"
                        HorizontalOptions="Start"
                        Clicked="OnLoginClicked"
                        Margin="0,15,0,0" />

            </VerticalStackLayout>

            <Image Grid.Column="1"
                   Source="monsterlogin.jpg"
                   Aspect="AspectFill"
                   WidthRequest="180"
                   HeightRequest="330"
                   VerticalOptions="Center"
                   Margin="0,0,0,0" />

        </Grid>
    </ScrollView>
</ContentPage>