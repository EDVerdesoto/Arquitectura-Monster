@page "/login"
@inject ClienteWeb.Modelo.ServicioSesion Sesion
@inject ClienteWeb.Controlador.AuthControlador AuthControlador
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Iniciar Sesion</PageTitle>

<div class="login-page">
    <div class="login-container">
        <div class="login-form">
            <div class="login-title">Ingrese sus credenciales:</div>

            @if (!string.IsNullOrEmpty(mensaje))
            {
                <div class="mensaje-frame @(exito ? "mensaje-exito" : "mensaje-error")">
                    @mensaje
                </div>
            }

            <div class="field-group">
                <label for="usuario" class="field-label">Usuario</label>
                <input type="text" class="field-input" id="usuario" @bind="usuario" placeholder="Ingrese su usuario" />
            </div>

            <div class="field-group">
                <label for="clave" class="field-label">Contrasena</label>
                <input type="password" class="field-input" id="clave" @bind="clave" placeholder="Ingrese su contrasena" />
            </div>

            <button class="btn-login" @onclick="IniciarSesion">INICIAR SESION</button>
        </div>

        <div class="login-image">
            <img src="Media/monsterlogin.jpg" alt="Monster Login" />
        </div>
    </div>
</div>

@code {
    private string usuario = string.Empty;
    private string clave = string.Empty;
    private string mensaje = string.Empty;
    private bool exito = false;

    private async Task IniciarSesion()
    {
        mensaje = string.Empty;
        var resultado = await AuthControlador.IniciarSesionAsync(usuario, clave);
        exito = resultado.exito;
        mensaje = resultado.mensaje;

        if (exito)
        {
            Navigation.NavigateTo("/conversion");
        }
    }
}
