@inherits LayoutComponentBase
@inject ClienteWeb.Modelo.ServicioSesion Sesion
@inject ClienteWeb.Controlador.AuthControlador AuthControlador
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="app-layout">
    <header class="top-bar">
        @if (Sesion.EstaAutenticado)
        {
            <button class="btn btn-logout" @onclick="CerrarSesion">Cerrar Sesion</button>
        }
    </header>

    <main class="main-content">
        @Body
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    <span class="dismiss" @onclick="DismissError">x</span>
</div>

@code {
    private void CerrarSesion()
    {
        AuthControlador.CerrarSesion();
        Navigation.NavigateTo("/login", forceLoad: false);
        StateHasChanged();
    }

    private async Task DismissError()
    {
        await JS.InvokeVoidAsync("eval", "document.getElementById('blazor-error-ui').style.display='none'");
    }
}
