<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ClienteEscritorio.Vista.LoginPage"
             BackgroundColor="#0D0D0D">

    <ScrollView>
        <Grid Padding="20" 
              RowDefinitions="Auto"
              ColumnDefinitions="Auto, Auto" 
              HorizontalOptions="Center" 
              ColumnSpacing="20">

            <VerticalStackLayout Grid.Column="0" Spacing="16" Margin="0,20,0,0" MaximumWidthRequest="400">

                <Label Text="Ingrese sus credenciales:"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="#F2F2F2"
                       Margin="0,0,0,16" />

                <Border x:Name="MensajeFrame"
                        IsVisible="false"
                        Padding="12"
                        StrokeShape="RoundRectangle 8"
                        StrokeThickness="0"
                        Margin="0,0,0,10">
                    <Label x:Name="MensajeLabel"
                           FontSize="14"
                           TextColor="#F2F2F2"
                           HorizontalOptions="Center" />
                </Border>

                <Label Text="Usuario" FontSize="14" TextColor="#F2F2F2" />
                <Entry x:Name="UsuarioEntry"
                       Placeholder="Ingrese su usuario"
                       FontSize="16"
                       TextColor="#F2F2F2"
                       Margin="0,0,0,10" />

                <Label Text="Contrasena" FontSize="14" TextColor="#F2F2F2" />
                <Entry x:Name="ClaveEntry"
                       Placeholder="Ingrese su contrasena"
                       IsPassword="True"
                       FontSize="16"
                       TextColor="#F2F2F2"
                       Margin="0,0,0,10" />

                <Button x:Name="LoginButton"
                        Text="INICIAR SESION"
                        FontAttributes="Bold"
                        FontSize="16"
                        BackgroundColor="#527AF2"
                        TextColor="#F2F2F2"
                        Clicked="OnLoginClicked"
                        Margin="0,0,0,10" />

            </VerticalStackLayout>

            <Image Grid.Column="1"
                   Source="monsterlogin.jpg"
                   Aspect="AspectFit"
                   MaximumWidthRequest="300"
                   MaximumHeightRequest="400"
                   VerticalOptions="Center"
                   Margin="16,0,0,0" />

        </Grid>
    </ScrollView>
</ContentPage>
