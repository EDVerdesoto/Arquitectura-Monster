<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:modelo="clr-namespace:ClienteMovil.Modelo"
             x:Class="ClienteMovil.Vista.ConversionPage"
             BackgroundColor="#0D0D0D">

    <ScrollView>
        <VerticalStackLayout Padding="20,30" Spacing="16" MaximumWidthRequest="600"
                              HorizontalOptions="Center">

            <Border x:Name="NoAutenticadoFrame"
                    IsVisible="True"
                    Padding="15"
                    StrokeShape="RoundRectangle 8"
                    StrokeThickness="0"
                    BackgroundColor="#664D00">
                <Label Text="Debe iniciar sesion para usar el conversor."
                       FontSize="14"
                       TextColor="#F2F2F2"
                       HorizontalOptions="Center" />
            </Border>

            <VerticalStackLayout x:Name="ContenidoConversion" IsVisible="False" Spacing="16">

                <Border x:Name="MensajeFrame"
                        IsVisible="false"
                        Padding="12"
                        StrokeShape="RoundRectangle 8"
                        StrokeThickness="0"
                        Margin="0,0,0,6">
                    <Label x:Name="MensajeLabel"
                           FontSize="14"
                           TextColor="#F2F2F2"
                           HorizontalOptions="Center" />
                </Border>

                <Label Text="Elija el tipo de unidad para la conversion" FontSize="16" FontAttributes="Bold" TextColor="#F2F2F2" />
                <Picker x:Name="TipoPicker"
                        FontSize="16"
                        TextColor="#F2F2F2"
                        SelectedIndexChanged="OnTipoChanged" />

                <Grid x:Name="ConversionGrid"
                      ColumnDefinitions="*,Auto,*"
                      RowDefinitions="Auto,Auto"
                      Margin="0,10,0,0">

                    <Border Grid.Column="0" Grid.Row="0"
                            Padding="12"
                            StrokeShape="RoundRectangle 8"
                            Stroke="#404040">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Unidad de Origen" FontAttributes="Bold" FontSize="13" TextColor="#F2F2F2" />
                            <Picker x:Name="OrigenPicker"
                                    TextColor="#F2F2F2"
                                    FontSize="14" />
                            <Label Text="Valor" FontAttributes="Bold" FontSize="13" TextColor="#F2F2F2" />
                            <Entry x:Name="ValorEntry"
                                   Placeholder="Ingrese el valor"
                                   Keyboard="Numeric"
                                   TextColor="#F2F2F2"
                                   FontSize="14" />
                        </VerticalStackLayout>
                    </Border>

                    <Image Grid.Column="1" Grid.Row="0"
                           Source="flecha40px.png"
                           HeightRequest="30"
                           WidthRequest="30"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           Margin="8,0" />

                    <Border Grid.Column="2" Grid.Row="0"
                            Padding="12"
                            StrokeShape="RoundRectangle 8"
                            Stroke="#404040">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Unidad de Destino" FontAttributes="Bold" FontSize="13" TextColor="#F2F2F2" />
                            <Picker x:Name="DestinoPicker"
                                    TextColor="#F2F2F2"
                                    FontSize="14" />
                            <Label Text="Resultado" FontAttributes="Bold" FontSize="13" TextColor="#F2F2F2" />
                            <Entry x:Name="ResultadoEntry"
                                   IsReadOnly="True"
                                   Placeholder="Resultado"
                                   TextColor="#F2F2F2"
                                   FontSize="14" />
                        </VerticalStackLayout>
                    </Border>

                    <Button x:Name="ConvertirButton"
                            Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1"
                            Text="CONVERTIR"
                            FontAttributes="Bold"
                            FontSize="18"
                            BackgroundColor="#527AF2"
                            TextColor="#F2F2F2"
                            Clicked="OnConvertirClicked"
                            Margin="0,10,0,0" />

                </Grid>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>